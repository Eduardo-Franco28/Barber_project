# Servidor
PORT=3000
NODE_ENV=development

# CORS — origem(ns) do front (SPA React). Em produção use a URL do Vercel,
# nunca "*". Aceita várias separadas por vírgula (ex.: domínio + previews):
#   CORS_ORIGIN=https://bryan.vercel.app,https://bryan-git-main.vercel.app
CORS_ORIGIN=http://localhost:5173

# SameSite do cookie de sessão. Padrão: 'lax' em dev, 'none' em produção.
# 'none' é necessário quando front (Vercel) e back (Render) ficam em domínios
# diferentes — exige HTTPS (Secure). Com domínio próprio (api.seusite.com +
# seusite.com) pode fixar 'lax' aqui. Deixe em branco para usar o padrão.
COOKIE_SAMESITE=

# Supabase (painel do projeto → Settings → API)
# URL do projeto, ex: https://abcdefgh.supabase.co
SUPABASE_URL=
# Chave SECRETA, só do servidor: "sb_secret_..." (API keys novas) ou a chave
# "service_role" (legadas). Nunca usar no front, nunca commitar.
SUPABASE_SECRET_KEY=

# Auth (JWT)
# Gere um segredo forte com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Opcionais (defaults: access 15min, refresh 7 dias)
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Fuso horário da barbearia (horários de funcionamento/fixos são hora local)
BARBERSHOP_TIMEZONE=America/Sao_Paulo

# Planilha espelho da agenda (relativo à pasta backend/, ou caminho absoluto —
# ex.: uma pasta do OneDrive/Dropbox para o barbeiro abrir de qualquer lugar).
# O barbeiro também baixa a planilha sempre atual pelo app (GET /spreadsheet).
EXCEL_FILE_PATH=data/agenda.xlsx

# Espelho em disco da planilha. Em hospedagem com disco efêmero (Render),
# defina EXCEL_MIRROR_ENABLED=false — o download sob demanda continua ok.
EXCEL_MIRROR_ENABLED=true

# Evolution API (WhatsApp) — OPCIONAL. Sem estas 3 variáveis, o app roda em
# modo SIMULADO: as mensagens aparecem no log do servidor e nada é enviado.
# Ao ativar, use um número DEDICADO da barbearia (não o pessoal) — ver
# CLAUDE.md > Notificações para o trade-off de risco.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
